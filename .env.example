# ─────────────────────────────────────────────────────────────
# Study Cost Planning Agent — environment configuration
# Copy this file to `.env` and fill in the values.
# ─────────────────────────────────────────────────────────────

# --- LLM (OpenRouter, OpenAI-compatible) ---
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Primary free model (good JSON adherence). Fallback used if primary is rate-limited.
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-chat-v3-0324:free
# Optional attribution headers for OpenRouter analytics
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_TITLE=Study Cost Planning Agent

# --- Database (Postgres + pgvector) ---
POSTGRES_USER=studyplanner
POSTGRES_PASSWORD=studyplanner
POSTGRES_DB=studyplanner
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Full URL used by the backend (host=db inside docker-compose network)
DATABASE_URL=postgresql+psycopg://studyplanner:studyplanner@db:5432/studyplanner

# --- Currency ---
# Frankfurter (ECB data) requires no key. Override only if self-hosting.
FRANKFURTER_BASE_URL=https://api.frankfurter.app
FX_CACHE_HOURS=24

# --- App behaviour ---
DEFAULT_REPORT_CURRENCY=EUR
SOURCE_STALE_MONTHS=18

# --- Frontend ---
# Browser-facing base URL of the backend API
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
